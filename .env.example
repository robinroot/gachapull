# =============================================
#   GachaPull — Environment Variables
#   Copy this to .env and fill in the values
# =============================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://gachapull:STRONG_PASSWORD@localhost:5432/gachapull

# JWT Secret — ganti dengan random string panjang
JWT_SECRET=gachapull-super-secret-jwt-key-change-this-in-production-min-32-chars

# App
NODE_ENV=production
LOG_LEVEL=info

# CORS — daftar origin yang diizinkan, pisah dengan koma
# Contoh: https://gachapull.com,https://www.gachapull.com
# Kosongkan untuk izinkan semua (tidak aman untuk production!)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
